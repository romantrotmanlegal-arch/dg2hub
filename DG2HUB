-- --- ADMIN DETECTION SETUP ---
local activeAdmins = {}

local function UpdateDashboardStatus()
    local count = 0
    local lastAdminName = ""
    for name, _ in pairs(activeAdmins) do
        count = count + 1
        lastAdminName = name
    end
    
    if count == 0 then
        adminStatusLabel.Text = "🛡️ NO ADMINS IN GAME — YOU'RE GOOD"
        adminStatusLabel.TextColor3 = Color3.fromRGB(100, 255, 100)
    elseif count == 1 then
        adminStatusLabel.Text = "⚠️ WARNING: 1 ADMIN ON (" .. lastAdminName .. ") — LEAVE TO AVOID GETTING CAUGHT!"
        adminStatusLabel.TextColor3 = Color3.fromRGB(255, 80, 80)
    else
        adminStatusLabel.Text = "🚨 CRITICAL: " .. count .. " ADMINS ON — LEAVE SVR IMMEDIATELY!"
        adminStatusLabel.TextColor3 = Color3.fromRGB(255, 40, 40)
    end
end

local function CheckForAdmin(player)
    if player == LocalPlayer then return end
    
    local modules = ReplicatedStorage:FindFirstChild("Modules")
    local cmdrConfigOpt = modules and modules:FindFirstChild("CmdrConfig")
    
    if cmdrConfigOpt and cmdrConfigOpt:IsA("ModuleScript") then
        local success, config = pcall(require, cmdrConfigOpt)
        if success and config and config.Admins then
            if table.find(config.Admins, player.Name) then
                activeAdmins[player.Name] = true
                UpdateDashboardStatus()
                Notify("ADMIN DETECTED", player.Name .. " is in the server!", Color3.fromRGB(255, 80, 80))
            end
        end
    end
end

local function RemoveAdmin(player)
    if activeAdmins[player.Name] then
        activeAdmins[player.Name] = nil
        UpdateDashboardStatus()
        Notify("ADMIN LEFT", player.Name .. " has left the server.", Color3.fromRGB(100, 150, 255))
    end
end

for _, player in ipairs(Players:GetPlayers()) do
    CheckForAdmin(player)
end
UpdateDashboardStatus()

Players.PlayerAdded:Connect(CheckForAdmin)
Players.PlayerRemoving:Connect(RemoveAdmin)
