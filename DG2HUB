-- --- SINGLE-EXECUTION WEAPON TP LOGIC ---
local function ExecuteWeaponTp()
    if SelectedWeapon == "" then 
        return Notify("Weapon TP", "No weapon selected in the dropdown!", Color3.fromRGB(255, 80, 80)) 
    end
    
    local cratesFolder = workspace:FindFirstChild("Crates")
    local weaponCrates = cratesFolder and cratesFolder:FindFirstChild("WeaponCrates")
    local targetWeaponFolder = weaponCrates and weaponCrates:FindFirstChild(SelectedWeapon)
    if not targetWeaponFolder then 
        return Error("Target weapon folder not found inside workspace!") 
    end

    local validCrateFound = false

    for _, weaponModel in ipairs(targetWeaponFolder:GetChildren()) do
        if weaponModel:IsA("Model") then
            local giver = weaponModel:FindFirstChild("Giver")
            local stockObj = giver and giver:FindFirstChild("Stock")
            local prompt = giver and giver:FindFirstChildOfClass("ProximityPrompt")

            if giver and stockObj and stockObj:IsA("ValueBase") and stockObj.Value > 0 and prompt and HRP then
                validCrateFound = true
                local oldCFrame = HRP.CFrame
                
                Notify("Weapon TP", "Teleporting to stocked " .. SelectedWeapon .. " crate...", Color3.fromRGB(80, 255, 120))
                HRP.CFrame = giver.CFrame + Vector3.new(0, 3, 0)
                task.wait(0.4)
                
                pcall(function() fireproximityprompt(prompt) end)
                task.wait(0.4)
                
                HRP.CFrame = oldCFrame
                Notify("Weapon TP", "Returned safely!", Color3.fromRGB(80, 120, 255))
                break
            end
        end
    end

    if not validCrateFound then
        Notify("Weapon TP", "All crates for " .. SelectedWeapon .. " are currently out of stock!", Color3.fromRGB(255, 150, 50))
    end
end

