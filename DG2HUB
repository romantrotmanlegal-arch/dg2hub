    ["Torso"] = false,
    ["Left Arm"] = false,
    ["Right Arm"] = false,
    ["Left Leg"] = false,
    ["Right Leg"] = false
}

local OriginalSizes = {
    ["Head"] = Vector3.new(2, 1, 1),
    ["Torso"] = Vector3.new(2, 2, 1),
    ["Left Arm"] = Vector3.new(1, 2, 1),
    ["Right Arm"] = Vector3.new(1, 2, 1),
    ["Left Leg"] = Vector3.new(1, 2, 1),
    ["Right Leg"] = Vector3.new(1, 2, 1)
}

local function RevertHitboxes()
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character then
            pcall(function()
                for partName, defaultSize in pairs(OriginalSizes) do
                    local realPart = player.Character:FindFirstChild(partName)
                    if realPart and realPart:IsA("BasePart") then
                        realPart.Size = defaultSize
                        realPart.Transparency = 0
                        realPart.CanCollide = true
                        realPart.Massless = false
                    end
                end
            end)
        end
    end
end

CreateToggle(playerPage, "Hitbox Extender", 20, function(v) 
    HitboxEnabled = v 
    if not v then RevertHitboxes() end
end)

CreateTextBox(playerPage, "Hitbox Size", 75, "10", function(text) 
    local num = tonumber(text)
    if num then HitboxSize = num end
end)

CreateMultiDropdown(playerPage, "Target Parts", 130, {"Head", "Torso", "Left Arm", "Right Arm", "Left Leg", "Right Leg"}, HitboxTargets, function()
    if not HitboxEnabled then RevertHitboxes() end
end)

-- --- WEAPON TAB SELECTION ---
local function RefillAmmoAction()
    if not HRP then return Error("HumanoidRootPart missing") end
    
    local ammoCratesFolder = workspace:FindFirstChild("Crates") and workspace.Crates:FindFirstChild("AmmoCrates")
    if not ammoCratesFolder then return Error("AmmoCrates folder not found in workspace!") end
    
    local targetGiver = nil
    local targetPrompt = nil
    
    for _, box in ipairs(ammoCratesFolder:GetChildren()) do
        if box.Name == "AMMOBox" then
            local giver = box:FindFirstChild("Giver")
            local stockObj = giver and giver:FindFirstChild("Stock")
            local prompt = giver and giver:FindFirstChildOfClass("ProximityPrompt")
            
            if giver and stockObj and prompt and stockObj.Value > 0 then
                targetGiver = giver
                targetPrompt = prompt
                break
            end
        end
    end
    
    if targetGiver and targetPrompt then
        local oldCFrame = HRP.CFrame
        Notify("Ammo Refill", "Teleporting to AMMOBox...", Color3.fromRGB(80, 255, 120))
         
        HRP.CFrame = targetGiver.CFrame + Vector3.new(0, 3, 0)
        task.wait(0.35)
        
        pcall(function() fireproximityprompt(targetPrompt) end)
        task.wait(0.4)
        
        HRP.CFrame = oldCFrame
        Notify("Ammo Refill", "Returned safely!", Color3.fromRGB(80, 120, 255))
    else
        Error("No filled AMMOBoxes found nearby!")
    end
end

CreateButton(weaponPage, "Refill Weapon Ammo", 20, function()
    Try(RefillAmmoAction, "Refill Ammo Loop")
end)

-- --- BACKGROUND FARM LOOP FOR GRENADES ---
local function ProcessGrenades()
    local cratesFolder = workspace:FindFirstChild("Crates")
    local weaponCrates = cratesFolder and cratesFolder:FindFirstChild("WeaponCrates")
    local grenadeFolder = weaponCrates and weaponCrates:FindFirstChild("GRENADE")
    if not grenadeFolder then return end

    for _, box in ipairs(grenadeFolder:GetChildren()) do
        if not GrenadeFarmActive then break end

        if box.Name == "GRENADEBox" then
            local giver = box:FindFirstChild("Giver")
            local stockObj = giver and giver:FindFirstChild("Stock")
            local prompt = giver and giver:FindFirstChildOfClass("ProximityPrompt")

            if giver and stockObj and prompt and stockObj.Value > 0 and HRP then
                local oldCFrame = HRP.CFrame
                
                HRP.CFrame = giver.CFrame + Vector3.new(0, 3, 0)
                task.wait(0.4)
                
                pcall(function() fireproximityprompt(prompt) end)
                task.wait(0.4)
                
                HRP.CFrame = oldCFrame
                task.wait(0.5)
            end
        end
    end
end

local function IsValidCrate(crate)
    if not crate:IsA("Model") then return false end
    local misc = crate:FindFirstChild("Misc")
    if not misc or not misc:IsA("Model") then return false end
    
    for _, obj in ipairs(misc:GetDescendants()) do
        if obj:IsA("BasePart") and obj.Transparency == 0 then
            return true
        end
    end
    return false
end

local function GetTeleportPart(crate)
    for _, obj in ipairs(crate:GetDescendants()) do
        if obj:IsA("BasePart") then return obj end
    end
    return nil
end

local function UseNearbyPrompts()
    for _, obj in ipairs(workspace:GetDescendants()) do
        if obj:IsA("ProximityPrompt") then
            local parent = obj.Parent
            if parent and parent:IsA("BasePart") then
                local distance = (HRP.Position - parent.Position).Magnitude
                if distance <= 15 then
                    pcall(function() fireproximityprompt(obj) end)
                    task.wait(0.15)
                end
            end
        end
    end
end

local function ProcessCrates(folderName, crateName, isToggleActive)
    local cratesFolder = workspace:FindFirstChild("Crates")
    local lootFolder = cratesFolder and cratesFolder:FindFirstChild("LootCrates")
    local targetFolder = lootFolder and lootFolder:FindFirstChild(folderName)
    if not targetFolder then return end

    for _, crate in ipairs(targetFolder:GetChildren()) do
        if not isToggleActive() then break end

        if crate.Name == crateName and IsValidCrate(crate) then
            local tpPart = GetTeleportPart(crate)
            if tpPart and HRP then 
                HRP.CFrame = tpPart.CFrame + Vector3.new(0, 3, 0) 
                task.wait(0.4)
                UseNearbyPrompts()
                task.wait(0.5)
            end
        end
    end
end

local function ProcessBunker()
    local bunker = workspace:FindFirstChild("Bunker")
    local cratesFolder = bunker and bunker:FindFirstChild("BunkerCrates")
    if not cratesFolder then return end

    for _, crate in ipairs(cratesFolder:GetChildren()) do
        if not T3 then break end

        if crate.Name == "T3Crate" and IsValidCrate(crate) then
            local tpPart = GetTeleportPart(crate)
            if tpPart and HRP then 
                HRP.CFrame = tpPart.CFrame + Vector3.new(0, 3, 0) 
                task.wait(0.4)
                UseNearbyPrompts()
                task.wait(0.5)
            end
        end
    end
end

task.spawn(function()
    while true do
        task.wait(0.2)
        if not Busy then
            Busy = true
            
            Try(function()
                if T1 then ProcessCrates("T1", "T1Crate", function() return T1 end) end
                if T2 then ProcessCrates("T2", "T2Crate", function() return T2 end) end
                if T3 then ProcessBunker() end
                if GrenadeFarmActive then ProcessGrenades() end
            end, "Farm Loop")
            Busy = false
        end
    end
end)

RunService.Heartbeat:Connect(function()
    if not HitboxEnabled then return end
    
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character then
            pcall(function()
                for partName, isTargeted in pairs(HitboxTargets) do
                    local realPart = player.Character:FindFirstChild(partName)
                    if realPart and realPart:IsA("BasePart") then
                        if isTargeted then
                            if realPart.Size.X ~= HitboxSize or realPart.Transparency ~= 0.55 then
                                realPart.Size = Vector3.new(HitboxSize, HitboxSize, HitboxSize)
                                realPart.Transparency = 0.55
                                realPart.Color = Color3.fromRGB(255, 50, 50)
                                realPart.CanCollide = false
                                realPart.Massless = true
                            end
                        else
                            local defaultSize = OriginalSizes[partName]
                            if realPart.Size.X ~= defaultSize.X or realPart.Transparency ~= 0 then
                                realPart.Size = defaultSize
                                realPart.Transparency = 0
                                realPart.CanCollide = true
                                realPart.Massless = false
                            end
                        end
                    end
                end
            end)
        end
    end
end)

