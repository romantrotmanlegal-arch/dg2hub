local function Error(msg)
    Notify("Execution Error", msg, Color3.fromRGB(255, 80, 80))
    warn("DG2 HUB ERROR: " .. msg)
end

local function Try(fn, context)
    local ok, result = pcall(fn)
    if not ok then Error(context .. ": " .. tostring(result)) end
end

